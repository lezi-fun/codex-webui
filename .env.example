HOST=127.0.0.1
PORT=8899
# Optional compatibility token for Basic/Bearer clients.
# CODEX_WEBUI_ACCESS_TOKEN=replace-with-a-long-random-secret

# Optional browser login password for LAN access. Localhost bypasses the login screen.
# When unset, CODEX_WEBUI_ACCESS_TOKEN remains the compatibility password.
# CODEX_WEBUI_PASSWORD=replace-with-a-long-random-password
# Defaults to the repository directory.
CODEX_WEBUI_CWD=/path/to/your/project
# Undo/Reapply is restricted to this exact Git repository root by default.
CODEX_WEBUI_REVIEW_ROOT=/path/to/your/project
# Optional custom Codex state/auth locations.
# CODEX_HOME=/path/to/.codex
# CODEX_AUTH_PATH=/path/to/.codex/auth.json
# Optional browser binary for Playwright scripts.
PLAYWRIGHT_EXECUTABLE_PATH=/path/to/chrome-or-edge
